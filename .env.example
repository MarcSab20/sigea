# ── Base de données ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigea
DB_USER=sigea_app
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=sigea
RABBITMQ_PASSWORD=CHANGE_ME_RABBIT_PASSWORD
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# ── JWT RS256 (clés générées avec: openssl genrsa -out jwt.key 4096) ────────
JWT_PRIVATE_KEY_PATH=./keys/jwt.private.key
JWT_PUBLIC_KEY_PATH=./keys/jwt.public.key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Chiffrement CEMAA (AES-256-GCM) ─────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CEMAA_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_KEY

# ── Services (ports) ─────────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
REFERENTIEL_SERVICE_PORT=3002
VOL_SERVICE_PORT=3003
MANIFESTE_SERVICE_PORT=3004
VALIDATION_SERVICE_PORT=3005
CEMAA_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
PDF_SERVICE_PORT=3008

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000/notifications

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
