{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/jest.config.ts",
      "!{projectRoot}/.eslintrc.json"
    ],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.base.json"]
  },
  "targetDefaults": {
    "build": { "dependsOn": ["^build"], "inputs": ["production", "^production"], "cache": true },
    "test":  { "inputs": ["default", "^production"], "cache": true },
    "lint":  { "inputs": ["default"], "cache": true }
  },
  "plugins": [
    { "plugin": "@nx/nest",  "options": { "targetName": "serve" } },
    { "plugin": "@nx/react", "options": { "targetName": "serve" } }
  ]
}
