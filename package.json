{
  "name": "sigea",
  "version": "1.0.0",
  "private": true,
  "description": "Système Intégré de Gestion des Escales Aériennes — FAC",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "nx run-many --target=serve --all --parallel=10",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "db:migrate": "nx run shared-database:migrate",
    "db:seed": "nx run shared-database:seed",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@nx/eslint": "18.x",
    "@nx/jest": "18.x",
    "@nx/nest": "18.x",
    "@nx/node": "18.x",
    "@nx/react": "18.x",
    "@nx/webpack": "18.x",
    "@nx/workspace": "18.x",
    "@prisma/client": "^5.22.0",
    "@swc/core": "^1.4.0",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/bcryptjs": "^2.4.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nx": "18.x",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/axios":"^4.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/throttler": "^6.0.0",
    "axios":"^1.6.8",
    "@nestjs/platform-express": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "@nestjs/terminus": "^11.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.1",
    "passport-jwt": "^4.0.1",
    "passport-local":  "^1.0.0",
    "@types/passport-jwt":"^4.0.1",
    "@types/passport-local":"^1.0.38",
    "otplib": "^12.0.1",
    "qrcode":"^1.5.3",
    "@types/qrcode":"^1.5.5",
    "ioredis":"^5.3.2",
    "@types/bcrypt":"^5.0.2",
    "rxjs": "^7.8.1",
    "puppeteer": "^22.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "socket.io": "^4.7.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
